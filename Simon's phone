<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Simon Riley — iPhone</title>
<style>
  :root{
    --bg:#000;
    --ink:#F5F5F7;
    --ink-dim:#9A9AA0;
    --ink-faint:#5C5C60;
    --surface:#19191B;
    --surface-2:#232326;
    --hair:rgba(255,255,255,0.08);
    --racing-blue:#1E2A78;
    --racing-red:#C8102E;
    --gold:#C9A86A;
    --green-live:#33D17A;
    --radius-phone:54px;
    --radius-card:22px;
    --font: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Helvetica Neue", Arial, sans-serif;
    --font-mono: "SF Mono", "Menlo", monospace;
  }
  *{box-sizing:border-box; -webkit-tap-highlight-color:transparent;}
  [style*="overflow-y:auto"], .gramly-scroll, .thread-body{
    -webkit-overflow-scrolling:touch;
    overscroll-behavior:contain;
  }
  html,body{height:100%;}
  body{
    margin:0;
    min-height:100dvh;
    display:flex;
    align-items:center;
    justify-content:center;
    background:
      radial-gradient(ellipse at 50% -10%, #1a1a1d 0%, #050505 55%, #000 100%);
    font-family:var(--font);
    color:var(--ink);
    padding:16px;
  }

  /* ================= PHONE FRAME ================= */
  .stage{
    position:relative;
  }
  .device-wrap{
    position:absolute;
    top:0; left:0;
    width:375px;
    height:812px;
    transform-origin:top left;
  }
  .device{
    position:relative;
    width:100%;
    height:100%;
    background:#000;
    border-radius:var(--radius-phone);
    border:7px solid #0a0a0a;
    box-shadow:
      0 0 0 1.5px #2c2c2e,
      0 30px 70px -20px rgba(0,0,0,0.85),
      0 0 120px -40px rgba(180,180,200,0.15);
    overflow:hidden;
    isolation:isolate;
  }
  .island{
    position:absolute;
    top:14px; left:50%; transform:translateX(-50%);
    width:108px; height:30px;
    background:#000;
    border-radius:20px;
    z-index:50;
    display:flex; align-items:center; justify-content:flex-end;
    padding-right:10px;
    gap:5px;
  }
  .island .cam-dot{
    width:8px; height:8px; border-radius:50%;
    background:radial-gradient(circle at 35% 35%, #2c2c34, #050507);
  }
  .island .live-dot{
    width:6px; height:6px; border-radius:50%;
    background:var(--green-live);
    box-shadow:0 0 6px var(--green-live);
    opacity:0;
    transition:opacity .4s;
  }
  .island.show-live .live-dot{opacity:1;}

  .screen{
    position:absolute; inset:0;
    opacity:0;
    pointer-events:none;
    transform:scale(1.02);
    transition:opacity .45s ease, transform .45s ease;
  }
  .screen.active{
    opacity:1;
    pointer-events:auto;
    transform:scale(1);
    z-index:5;
  }

  /* ================= STATUS BAR ================= */
  .statusbar{
    position:absolute; top:0; left:0; right:0;
    height:54px;
    display:flex; align-items:flex-end;
    justify-content:space-between;
    padding:0 26px 8px 30px;
    font-size:15px; font-weight:600;
    letter-spacing:0.2px;
    z-index:40;
    color:var(--ink);
  }
  .statusbar .right{display:flex; align-items:center; gap:5px;}
  .sig-bars{display:flex; align-items:flex-end; gap:2px; height:11px;}
  .sig-bars span{width:3px; background:var(--ink); border-radius:1px;}
  .sig-bars span:nth-child(1){height:4px;}
  .sig-bars span:nth-child(2){height:6px;}
  .sig-bars span:nth-child(3){height:8px;}
  .sig-bars span:nth-child(4){height:11px;}
  .wifi-icon{width:15px; height:11px;}
  .batt{display:flex; align-items:center; gap:4px;}
  .batt-shell{width:24px; height:12px; border:1.3px solid var(--ink); border-radius:3.5px; position:relative; padding:1.5px;}
  .batt-shell::after{content:""; position:absolute; right:-3px; top:3px; width:2px; height:5px; background:var(--ink); border-radius:0 2px 2px 0;}
  .batt-fill{height:100%; width:87%; background:var(--ink); border-radius:1.5px;}

  /* ================= LOCK SCREEN ================= */
  #screen-lock{
    background:#0c0c0e;
  }
  .lock-bg{
    position:absolute; inset:0;
    background:linear-gradient(165deg, #2b1a12 0%, #3a2010 28%, #1a1410 55%, #0a0a0c 100%);
    overflow:hidden;
  }
  .lock-bg img{
    position:absolute; inset:0;
    width:100%; height:100%;
    object-fit:cover;
    object-position:center 62%;
    opacity:0;
    transition:opacity .5s ease;
  }
  .lock-bg img.loaded{opacity:1;}
  .lock-bg::after{
    content:"";
    position:absolute; inset:0;
    background:linear-gradient(180deg, rgba(0,0,0,0.42) 0%, rgba(0,0,0,0.05) 26%, rgba(0,0,0,0.12) 60%, rgba(0,0,0,0.78) 100%);
  }
  #screen-lock.off .lock-bg{filter:brightness(0) saturate(0);}
  #screen-lock.off .lock-content{opacity:0;}
  .lock-content{
    position:relative; z-index:10;
    height:100%;
    display:flex; flex-direction:column;
    padding-top:64px;
    transition:opacity .8s ease;
  }
  .lock-meta{
    text-align:center;
    color:#fff;
    text-shadow:0 1px 12px rgba(0,0,0,0.5);
  }
  .lock-loc{
    font-size:12.5px; font-weight:600;
    letter-spacing:0.4px;
    opacity:0.92;
    display:flex; align-items:center; justify-content:center; gap:5px;
  }
  .lock-time{
    font-size:78px; font-weight:700; line-height:1;
    margin-top:6px;
    letter-spacing:-1px;
    font-variant-numeric: tabular-nums;
  }
  .lock-date{
    font-size:16.5px; font-weight:600;
    margin-top:4px;
    text-transform:capitalize;
  }
  .lock-notifs{
    margin-top:22px;
    padding:0 16px;
    flex:1;
    overflow-y:auto;
    display:flex; flex-direction:column; gap:9px;
    scrollbar-width:none;
    padding-bottom:90px;
  }
  .lock-notifs::-webkit-scrollbar{display:none;}
  .ngroup-label{
    color:rgba(255,255,255,0.55);
    font-size:11px; font-weight:700;
    text-transform:uppercase; letter-spacing:0.8px;
    padding:6px 10px 2px;
  }
  .notif{
    background:rgba(60,60,67,0.42);
    backdrop-filter:blur(22px);
    -webkit-backdrop-filter:blur(22px);
    border-radius:16px;
    padding:11px 13px;
    display:flex; gap:10px;
    color:#fff;
    animation:slideDown .5s ease both;
  }
  @keyframes slideDown{from{opacity:0; transform:translateY(-14px);} to{opacity:1; transform:translateY(0);}}
  .notif-ic{
    width:30px; height:30px; border-radius:8px;
    flex-shrink:0;
    display:flex; align-items:center; justify-content:center;
    font-size:15px;
  }
  .notif-body{flex:1; min-width:0;}
  .notif-top{display:flex; justify-content:space-between; align-items:baseline; gap:8px;}
  .notif-app{font-size:12.5px; font-weight:700;}
  .notif-time{font-size:11px; color:rgba(255,255,255,0.55); flex-shrink:0;}
  .notif-msg{font-size:13px; color:rgba(255,255,255,0.92); margin-top:1px; line-height:1.3;}
  .notif-msg b{font-weight:700;}

  .swipe-hint{
    position:absolute; bottom:14px; left:0; right:0;
    z-index:20;
    text-align:center;
    color:#fff;
    text-shadow:0 1px 8px rgba(0,0,0,0.5);
    cursor:pointer;
    user-select:none;
    touch-action:none;
    padding-top:18px;
  }
  .lock-content.dragging{transition:none;}
  .lock-content.snap-back{transition:transform .32s cubic-bezier(.32,.72,0,1);}
  .swipe-chev{font-size:13px; opacity:0.85; animation:bob 1.8s ease-in-out infinite;}
  @keyframes bob{0%,100%{transform:translateY(0); opacity:.5;} 50%{transform:translateY(-4px); opacity:1;}}
  .swipe-bar{width:134px; height:5px; background:#fff; border-radius:3px; margin:8px auto 0; opacity:0.92;}
  .swipe-text{font-size:13px; font-weight:600; margin-top:6px;}

  /* ================= PASSCODE ================= */
  #screen-passcode{background:#000;}
  .pc-wrap{
    height:100%;
    display:flex; flex-direction:column; align-items:center;
    justify-content:flex-start;
    padding-top:clamp(36px, 9vh, 96px);
    padding-bottom:16px;
    overflow-y:auto;
    scrollbar-width:none;
  }
  .pc-wrap::-webkit-scrollbar{display:none;}
  .pc-faceid{
    width:56px; height:56px;
    border-radius:50%;
    background:var(--surface);
    display:flex; align-items:center; justify-content:center;
    font-size:25px;
    margin-bottom:14px;
    cursor:pointer;
    border:1px solid var(--hair);
    transition:transform .15s ease;
    flex-shrink:0;
  }
  .pc-faceid:active{transform:scale(0.93);}
  .pc-faceid.fail{animation:shakeX .45s;}
  @keyframes shakeX{
    0%,100%{transform:translateX(0);}
    20%{transform:translateX(-9px);}
    40%{transform:translateX(8px);}
    60%{transform:translateX(-6px);}
    80%{transform:translateX(4px);}
  }
  .pc-status{
    font-size:13.5px; font-weight:600;
    color:var(--ink-dim);
    height:17px;
    margin-bottom:14px;
    transition:color .2s;
    flex-shrink:0;
  }
  .pc-status.bad{color:#FF6961;}
  .pc-label{font-size:19px; font-weight:600; color:var(--ink); margin-bottom:24px; flex-shrink:0;}
  .pc-dots{display:flex; gap:16px; margin-bottom:26px; flex-shrink:0;}
  .pc-dot{
    width:13px; height:13px; border-radius:50%;
    border:1.6px solid var(--ink-dim);
    transition:background .15s, border-color .15s, transform .15s;
  }
  .pc-dot.filled{background:var(--ink); border-color:var(--ink); transform:scale(1.05);}
  .pc-dots.shake{animation:shakeX .45s;}
  .pc-keypad{
    display:grid;
    grid-template-columns:repeat(3, minmax(56px, 66px));
    gap:clamp(10px,2.5vh,18px) clamp(16px,5vw,24px);
    flex-shrink:0;
    padding-bottom:8px;
  }
  .pc-key{
    width:100%; aspect-ratio:1/1; border-radius:50%;
    background:var(--surface);
    border:1px solid var(--hair);
    color:var(--ink);
    font-size:24px; font-weight:400;
    display:flex; align-items:center; justify-content:center;
    cursor:pointer;
    user-select:none;
    transition:background .12s, transform .1s;
  }
  .pc-key:active{background:#3a3a3c; transform:scale(0.94);}
  .pc-key.ghost{background:transparent; border:none; cursor:default;}
  .pc-key.del{font-size:17px; font-weight:600;}
  .pc-hint{margin-top:20px; font-size:11px; color:var(--ink-faint); text-align:center; line-height:1.6; flex-shrink:0;}

  /* ================= HOME SCREENS ================= */
  .home-bg{
    position:absolute; inset:0;
    background:linear-gradient(165deg, #2b1a12 0%, #3a2010 28%, #1a1410 55%, #0a0a0c 100%);
    overflow:hidden;
  }
  .home-bg img{
    position:absolute; inset:0;
    width:100%; height:100%;
    object-fit:cover;
    object-position:center 62%;
    opacity:0;
    transition:opacity .5s ease;
  }
  .home-bg img.loaded{opacity:1;}
  .home-bg::after{content:""; position:absolute; inset:0; background:rgba(0,0,0,0.5);}
  .home-pages{
    position:relative; z-index:10;
    height:100%;
    display:flex; flex-direction:column;
    padding-top:62px;
  }
  .home-track{
    flex:1;
    display:flex;
    width:300%;
    transform:translateX(0px);
    touch-action:none;
    user-select:none;
  }
  .home-track.snap{
    transition:transform .38s cubic-bezier(.32,.72,0,1);
  }
  .home-page{
    width:33.333%;
    padding:6px 18px 0;
    display:grid;
    grid-template-columns:repeat(4, 1fr);
    gap:18px 10px;
    align-content:start;
  }
  .app-icon{
    display:flex; flex-direction:column; align-items:center;
    gap:5px;
    cursor:pointer;
    user-select:none;
  }
  .app-glyph{
    width:58px; height:58px; border-radius:15px;
    background:linear-gradient(155deg, var(--surface-2), var(--surface));
    border:1px solid var(--hair);
    display:flex; align-items:center; justify-content:center;
    font-size:25px;
    box-shadow:0 3px 8px rgba(0,0,0,0.35);
    transition:transform .12s;
  }
  .app-icon:active .app-glyph{transform:scale(0.9);}
  .app-icon.locked .app-glyph{background:linear-gradient(155deg,#1c1c1e,#000); border-color:rgba(255,255,255,0.12);}
  .app-label{
    font-size:11.5px; font-weight:500; color:#fff;
    text-shadow:0 1px 4px rgba(0,0,0,0.6);
    text-align:center; line-height:1.15;
  }
  .app-sub{font-size:9px; color:rgba(255,255,255,0.55); text-align:center; margin-top:-3px;}
  .vault-page{
    width:33.333%;
    display:flex; align-items:center; justify-content:center;
    flex-direction:column;
  }
  .home-dots{
    display:flex; justify-content:center; gap:7px;
    padding:10px 0 16px;
    position:relative; z-index:10;
  }
  .home-dot{width:7px; height:7px; border-radius:50%; background:rgba(255,255,255,0.35); transition:background .2s, transform .2s;}
  .home-dot.active{background:#fff; transform:scale(1.15);}
  .home-build-tag{
    position:absolute; bottom:34px; right:18px; z-index:15;
    font-size:9.5px; color:rgba(255,255,255,0.45);
    background:rgba(255,255,255,0.08);
    padding:3px 8px; border-radius:8px;
    letter-spacing:0.3px;
  }

  /* ================= APP DETAIL SHELL ================= */
  .app-screen{background:var(--bg);}
  .app-topbar{
    height:54px;
    padding-top:54px;
    display:flex; align-items:center;
    padding-left:14px; padding-right:14px;
    border-bottom:1px solid var(--hair);
    position:relative; z-index:10;
    flex-shrink:0;
  }
  .back-btn{
    display:flex; align-items:center; gap:2px;
    color:var(--ink);
    font-size:16px; font-weight:500;
    cursor:pointer;
    padding:6px 4px;
  }
  .back-btn .chev{font-size:21px; font-weight:600; margin-right:2px;}
  .app-title-center{
    position:absolute; left:50%; transform:translateX(-50%); top:54px;
    height:54px; display:flex; align-items:center;
    font-weight:700; font-size:16.5px; color:var(--ink);
  }

  /* ---- Phone App ---- */
  .phone-shell{height:100%; display:flex; flex-direction:column;}
  .phone-topbar{
    padding-top:54px;
    padding:54px 16px 8px;
    flex-shrink:0;
  }
  .phone-title-row{
    display:flex; align-items:center; justify-content:space-between;
    margin-bottom:10px;
  }
  .phone-title{font-size:25px; font-weight:700;}
  .phone-add-btn{
    width:30px; height:30px; border-radius:50%;
    background:var(--surface-2);
    border:1px solid var(--hair);
    display:flex; align-items:center; justify-content:center;
    font-size:16px; color:var(--ink);
    cursor:pointer;
  }
  .phone-search{
    background:var(--surface-2);
    border:1px solid var(--hair);
    border-radius:11px;
    padding:8px 12px;
    font-size:14.5px;
    color:var(--ink-dim);
    display:flex; align-items:center; gap:6px;
  }
  .phone-tabpanels{flex:1; overflow:hidden; position:relative;}
  .phone-panel{
    position:absolute; inset:0;
    overflow-y:auto;
    scrollbar-width:none;
    padding-bottom:16px;
    display:none;
  }
  .phone-panel::-webkit-scrollbar{display:none;}
  .phone-panel.active{display:block;}

  .phone-tabbar{
    display:flex;
    border-top:1px solid var(--hair);
    background:rgba(20,20,22,0.9);
    backdrop-filter:blur(20px);
    flex-shrink:0;
    padding-bottom:2px;
  }
  .phone-tab{
    flex:1;
    display:flex; flex-direction:column; align-items:center; gap:3px;
    padding:8px 0 6px;
    color:var(--ink-faint);
    font-size:10.5px; font-weight:600;
    cursor:pointer;
  }
  .phone-tab .ptab-ic{font-size:20px; line-height:1;}
  .phone-tab.active{color:#0A84FF;}

  .section-label{
    padding:14px 20px 4px;
    font-size:12px; font-weight:700;
    color:var(--ink-faint);
    text-transform:uppercase;
    letter-spacing:0.6px;
  }
  .contact-row{
    display:flex; align-items:center; gap:12px;
    padding:9px 20px;
    border-bottom:1px solid var(--hair);
    cursor:pointer;
  }
  .contact-avatar{
    width:42px; height:42px; border-radius:50%;
    flex-shrink:0;
    background:linear-gradient(155deg,#2c2c2e,#19191b);
    background-size:cover; background-position:center;
    display:flex; align-items:center; justify-content:center;
    font-size:14px; font-weight:700; color:#fff;
    border:1px solid var(--hair);
  }
  .contact-avatar.navy{background:#0B1F4B; color:#dfe6ff;}
  .contact-body{flex:1; min-width:0;}
  .contact-name{font-size:15.5px; font-weight:600; color:var(--ink);}
  .contact-desc{font-size:12px; color:var(--ink-dim); margin-top:1px;}
  .contact-muted{font-size:10.5px; color:var(--ink-faint); margin-top:1px;}
  .contact-call-ic{font-size:16px; color:var(--ink-faint); padding:4px;}

  .recent-row{
    display:flex; align-items:center; gap:12px;
    padding:10px 20px;
    border-bottom:1px solid var(--hair);
    cursor:pointer;
  }
  .recent-dir-ic{width:16px; flex-shrink:0; text-align:center; font-size:13px; margin-top:1px;}
  .recent-dir-ic.out{color:var(--ink-dim);}
  .recent-dir-ic.in{color:var(--ink-dim);}
  .recent-dir-ic.missed{color:#FF6961;}
  .recent-body{flex:1; min-width:0;}
  .recent-name{font-size:15.5px; font-weight:600;}
  .recent-name.missed{color:#FF6961;}
  .recent-sub{font-size:12.5px; color:var(--ink-faint); margin-top:1px;}
  .recent-meta{font-size:12px; color:var(--ink-faint); text-align:right; flex-shrink:0;}

  .vm-row{
    padding:11px 20px;
    border-bottom:1px solid var(--hair);
    display:flex; gap:12px;
    cursor:pointer;
  }
  .vm-dot{
    width:8px; height:8px; border-radius:50%;
    background:#0A84FF;
    margin-top:6px; flex-shrink:0;
    opacity:0;
  }
  .vm-row.unheard .vm-dot{opacity:1;}
  .vm-body{flex:1; min-width:0;}
  .vm-top{display:flex; justify-content:space-between; align-items:baseline;}
  .vm-name{font-size:15px; font-weight:700;}
  .vm-name.unheard{color:var(--ink);}
  .vm-name.heard{color:var(--ink-dim); font-weight:600;}
  .vm-time{font-size:11.5px; color:var(--ink-faint);}
  .vm-text{font-size:13px; color:var(--ink-dim); margin-top:3px; line-height:1.35;}
  .vm-controls{display:flex; align-items:center; gap:10px; margin-top:8px;}
  .vm-play{
    width:26px; height:26px; border-radius:50%;
    background:#0A84FF; color:#fff;
    display:flex; align-items:center; justify-content:center;
    font-size:11px; flex-shrink:0;
  }
  .vm-wave{flex:1; height:20px; display:flex; align-items:center; gap:2px;}
  .vm-wave span{width:2px; background:var(--ink-faint); border-radius:1px;}
  .vm-status{font-size:10.5px; color:var(--ink-faint); flex-shrink:0;}

  /* Calling overlay */
  .calling-overlay{
    position:absolute; inset:0; z-index:200;
    background:#0c0c0e;
    display:flex; flex-direction:column; align-items:center;
    padding-top:120px;
    opacity:0; pointer-events:none;
    transition:opacity .3s ease;
  }
  .calling-overlay.show{opacity:1; pointer-events:auto;}
  .calling-avatar{
    width:120px; height:120px; border-radius:50%;
    background:linear-gradient(155deg,#2c2c2e,#19191b);
    background-size:cover; background-position:center;
    border:1px solid var(--hair);
    margin-bottom:22px;
  }
  .calling-name{font-size:24px; font-weight:600; color:#fff;}
  .calling-status{font-size:15px; color:var(--ink-dim); margin-top:6px;}
  .calling-hangup{
    position:absolute; bottom:60px; left:50%; transform:translateX(-50%);
    width:66px; height:66px; border-radius:50%;
    background:#FF3B30;
    display:flex; align-items:center; justify-content:center;
    font-size:26px;
    cursor:pointer;
    transform:translateX(-50%) rotate(135deg);
    color:#fff;
  }
  /* ---- Vault ---- */
  .vault-shell{height:100%; display:flex; flex-direction:column;}
  .vault-body{flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:22px; background:#000;}
  .vault-scanner{
    width:92px; height:92px; border-radius:24px;
    border:1.5px solid #2c2c2e;
    display:flex; align-items:center; justify-content:center;
    font-size:40px;
    position:relative;
    overflow:hidden;
  }
  .vault-scanner::after{
    content:"";
    position:absolute; left:0; right:0; top:-100%;
    height:40%;
    background:linear-gradient(180deg, transparent, rgba(255,255,255,0.5), transparent);
